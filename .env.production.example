# =============================================================================
# Kena / Ingresso — referência de PRODUÇÃO
# Copie para .env no servidor e preencha os valores reais.
# NÃO commite o .env preenchido.
# =============================================================================

APP_NAME=Kena
APP_ENV=production
APP_KEY=                       # php artisan key:generate
APP_DEBUG=false
APP_URL=https://SEU-DOMINIO.com.br   # usado no webhook e nos magic-links

APP_LOCALE=pt_BR
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=pt_BR

# --- Log / erros ---
LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=warning              # em prod não use debug

# --- Banco (NÃO use sqlite em produção) ---
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=kena
DB_USERNAME=
DB_PASSWORD=

# --- Sessão / cache / fila ---
# Requer um worker rodando: `php artisan queue:work` (supervisor/systemd).
# Sem worker, e-mails de ingresso/reembolso/transferência NÃO são enviados.
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
QUEUE_CONNECTION=database
CACHE_STORE=database
# Recomendado migrar sessão/cache/fila para Redis sob carga.

# --- E-mail (obrigatório: MAIL_MAILER=log NÃO entrega) ---
MAIL_MAILER=smtp
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_SCHEME=tls
MAIL_FROM_ADDRESS="no-reply@SEU-DOMINIO.com.br"
MAIL_FROM_NAME="${APP_NAME}"

# --- Admin inicial (seed) ---
# Rode o seed uma vez com estes valores; depois remova a senha daqui.
ADMIN_NAME="Davi Moreira"
ADMIN_EMAIL=
ADMIN_PASSWORD=

# --- Google OAuth ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI="https://SEU-DOMINIO.com.br/auth/google/callback"

# --- Mercado Pago (produção) ---
# Preferível configurar pelo painel /dashboard/config (grava encriptado).
# O painel tem prioridade sobre o .env. Em produção o webhook secret é OBRIGATÓRIO.
MP_ACCESS_TOKEN=
MP_PUBLIC_KEY=
MP_WEBHOOK_SECRET=
MP_PIX_EXPIRATION_MINUTES=30

# --- Kena domínio ---
KENA_HOLD_MINUTES=10
KENA_SERVICE_FEE_PERCENT=10
KENA_REFUND_DEADLINE_HOURS=48
# Segredo dedicado dos QRs (fallback: APP_KEY). Defina um valor fixo: se ficar
# vazio, rotacionar o APP_KEY invalida todos os ingressos já emitidos.
KENA_QR_SECRET=

# --- Scheduler ---
# Requer cron: * * * * * php /caminho/artisan schedule:run >> /dev/null 2>&1
# Sem ele: holds não expiram, Pix não reconcilia, lembretes não são enviados.

VITE_APP_NAME="${APP_NAME}"
